{
  "default_pages": {
    "description": "默认爬取页数",
    "type": "int",
    "default": 5
  },
  "include_subs": {
    "description": "是否默认展开子评论",
    "type": "bool",
    "default": false
  },
  "auto_delete_csv": {
    "description": "发送后自动删除 CSV",
    "type": "bool",
    "default": true
  },
  "sort_by": {
    "description": "默认排序方式",
    "type": "string",
    "options": [
      "hot",
      "time"
    ],
    "default": "hot"
  },
  "token": {
    "description": "Bot Token",
    "type": "string",
    "default": ""
  },
  "fasong_csv": {
    "description": "是否发送 CSV 文件",
    "type": "bool",
    "default": true
  },
  "fasong_json": {
    "description": "是否发送 JSON 文件",
    "type": "bool",
    "default": false
  },
  "llm_summary": {
    "description": "启用 AI 总结评论",
    "type": "bool",
    "default": false
  },
  "llm_keywords": {
    "description": "AI 总结的关键词",
    "type": "text",
    "default": ""
  }
}